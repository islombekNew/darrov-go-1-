{
  "expo": {
    "name": "DarrovGo",
    "slug": "darrovgo",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.darrovgo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#FF6B1A"
      },
      "package": "uz.darrovgo.app",
      "versionCode": 2,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "INTERNET"
      ]
    },
    "plugins": [
      ["expo-location", {
        "locationAlwaysAndWhenInUsePermission": "DarrovGo ilovasi yetkazib berish uchun joylashuvingizdan foydalanadi.",
        "locationWhenInUsePermission": "DarrovGo ilovasi yetkazib berish uchun joylashuvingizdan foydalanadi."
      }],
      ["expo-image-picker", {
        "photosPermission": "DarrovGo ilovasi profil rasmingizni o'rnatish uchun galereyangizdan foydalanadi.",
        "cameraPermission": "DarrovGo ilovasi profil rasmini olish uchun kameradan foydalanadi."
      }]
    ],
    "extra": {
      "eas": {
        "projectId": "a0420cf1-733b-4f26-9e7f-ef1ebaaa318f"
      }
    }
  }
}
