{
  "expo": {
    "name": "DarrovGo",
    "slug": "darrovgo-v3",
    "owner": "mnrtraxs-organization",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.darrovgo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "uz.darrovgo.app",
      "versionCode": 2,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "DarrovGo ilovasi yetkazib berish uchun joylashuvingizdan foydalanadi.",
          "locationWhenInUsePermission": "DarrovGo ilovasi yetkazib berish uchun joylashuvingizdan foydalanadi."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DarrovGo ilovasi profil rasmingizni o'rnatish uchun galereyangizdan foydalanadi.",
          "cameraPermission": "DarrovGo ilovasi profil rasmini olish uchun kameradan foydalanadi."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f0ca3748-e2d4-44ad-ad02-38d9ce5b04f8"
      }
    }
  }
}
